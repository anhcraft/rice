    "expectedErrorName": ""
  },
  {
    "name": "Block Expression without ending semicolon",
    "input": "{ a = 1; a + 1 }",
    "expectedOutput": [
      "(Block (Assign (Id a) (Int 1)) (Sum (Id a) (Int 1)))"
    ],
    "expectedErrorName": ""
  },
  {
    "name": "Block Expression with ending semicolon",
    "input": "{ a = 1; a + 1; }",
    "expectedOutput": [
      "(Block (Assign (Id a) (Int 1)) (Sum (Id a) (Int 1)))"
    ],
    "expectedErrorName": ""
  },
  {
    "name": "Block Expression followed by another expression",
    "input": "{ a = 1; a + 1; } true",
    "expectedOutput": [
      "(Block (Assign (Id a) (Int 1)) (Sum (Id a) (Int 1)))",
      "(Bool true)"
    ],
    "expectedErrorName": ""
  },
  {
    "name": "If Expression",
    "input": "if (age >= 18) { \"adult\" }",
    "expectedOutput": [
      "(If (Gte (Id age) (Int 18)) (Block (Str \"adult\")))"
    ],
    "expectedErrorName": ""
  },
  {
    "name": "If-Else Expression",
    "input": "if (x) { 1 } else { 2 }",
