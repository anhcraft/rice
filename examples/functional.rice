strings.join("\n", ...map.new().put("Fruit 1", "Apple","Fruit 2", "Banana","Fruit 3", "Cherry","Fruit 4", "Durian","Fruit 5", "Elderberry","Fruit 6", "Fig","Fruit 7", "Grape","Fruit 8", "Honeydew","Fruit 9", "Indian Plum","Fruit 10", "Jackfruit").filter(func(entry){typeof(entry[1]) == "String" && entry[1].toLower().include("a")}).entries().sort(func(a,b){a[1]<b[1]}).map(func(entry){entry[0]+": "+entry[1]}))