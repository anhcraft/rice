# 38. Insert Interval
# Given a set of non-overlapping intervals sorted by start time,
# insert a new interval and merge if necessary.
# Already exists as examples/insert-interval.rice; this is a self-testing version.

const insertInterval = func(intervals, newInterval) {
    const result = list.new();
    var i = 0;
    const n = len(intervals);

    for i < n {
        if intervals[i][1] >= newInterval[0] {
            break;
        }
        result.append(intervals[i]);
        i++;
    }

    var merged = newInterval;
    for i < n {
        if intervals[i][0] > merged[1] {
            break;
        }
        merged = list.of(math.min(merged[0], intervals[i][0]), math.max(merged[1], intervals[i][1]));
        i++;
    }
    result.append(merged);

    for i < n {
        result.append(intervals[i]);
        i++;
    }

    return result;
};

# Test 1
const r1 = insertInterval(list.of(list.of(1, 3), list.of(6, 9)), list.of(2, 5));
assert(r1[0][0] == 1 && r1[0][1] == 5 && r1[1][0] == 6 && r1[1][1] == 9, "Insert Interval test 1 failed");

# Test 2
const r2 = insertInterval(list.of(list.of(1, 2), list.of(3, 5), list.of(6, 7), list.of(8, 10), list.of(12, 16)), list.of(4, 8));
assert(r2[0][0] == 1 && r2[0][1] == 2, "Insert Interval test 2a failed");
assert(r2[1][0] == 3 && r2[1][1] == 10, "Insert Interval test 2b failed");
assert(r2[2][0] == 12 && r2[2][1] == 16, "Insert Interval test 2c failed");

# Test 3: Insert at beginning
const r3 = insertInterval(list.of(list.of(3, 5), list.of(8, 10)), list.of(1, 2));
assert(r3[0][0] == 1 && r3[0][1] == 2 && r3[1][0] == 3, "Insert Interval test 3 failed");

# Test 4: Insert at end
const r4 = insertInterval(list.of(list.of(1, 3)), list.of(5, 7));
assert(r4[0][0] == 1 && r4[0][1] == 3 && r4[1][0] == 5 && r4[1][1] == 7, "Insert Interval test 4 failed");

true
