# Operator precedence: verify that operators follow expected rules
# Multiplicative (* / %) binds tighter than additive (+ -)
# Additive binds tighter than comparison (< > <= >=)
# Comparison binds tighter than logical AND (&&)
# Logical AND binds tighter than logical OR (||)

# Multiplicative > Additive
const a = 2 + 3 * 4;  # 2 + 12 = 14 (NOT 2+3 * 4 = 20)

# Additive > Comparison
const b = 5 + 3 > 6;  # 8 > 6 = true (NOT 5 + (3 > 6) )

# Comparison > Logical AND
const c = 5 > 3 && 2 < 1;  # true && false = false

# Logical AND > Logical OR
const d = false && false || true && true;  # false || true = true
# This is ((false && false) || (true && true)) = false || true = true

# Unary > Multiplicative
const e = -3 * 4;  # -12
const f = !true && false;  # false && false = false

# Combined precedence test
const g = 1 + 2 * 3 > 5 && 10 - 4 == 6;  # (1+6 > 5) && (6 == 6) = true && true = true

a == 14 && b == true && c == false && d == true && e == -12 && f == false && g == true
