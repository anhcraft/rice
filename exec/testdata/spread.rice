# Spread operator: used within argument list to fill a collection
# into the argument list. Can be positioned anywhere.

# Spread a list
const nums = list.of(3, 4, 5);
const sumThree = func(a, b, c) {
    return a + b + c;
};
const a = sumThree(...nums);  # sumThree(3, 4, 5) = 12

# Spread a set
const s = set.of(10, 20);
const sumTwo = func(a, b) {
    return a + b;
};
const b = sumTwo(...set.of(1, 2));  # 3

# Spread positioned in the middle of arguments
const concat = func(a, b, c, d) {
    return string(a) + string(b) + string(c) + string(d);
};
const extra = list.of("B", "C");
const c = concat("A", ...extra, "D");  # "ABCD"

# Spread at the end
const d = concat("X", "Y", ...list.of("Z", "W"));  # "XYZW"

# Spread at the beginning
const e = concat(...list.of(1, 2), 3, 4);  # "1234"

# Spread with varargs
const sumAll = func(nums...) {
    var total = 0;
    for n in nums {
        total = total + n;
    }
    return total;
};
const f = sumAll(...list.of(1, 2, 3, 4, 5));  # 15

# Multiple spreads in single call
const sixArgs = func(a, b, c, d, e, f) {
    return a + b + c + d + e + f;
};
const g = sixArgs(...list.of(1, 2), ...list.of(3, 4), ...list.of(5, 6));  # 21

a == 12 && b == 3 && c == "ABCD" && d == "XYZW" && e == "1234" && f == 15 && g == 21
