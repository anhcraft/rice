[
  {
    "name": "Literals",
    "input": "123; \"hello\"; true; false; null",
    "expectedOutput": [
      "(Int 123)",
      "(Str \"hello\")",
      "(Bool true)",
      "(Bool false)",
      "(Null)"
    ],
    "expectedErrorName": ""
  },
  {
    "name": "Arithmetic Precedence",
    "input": "1 + 2 * 3 - 4 / 5 % 2",
    "expectedOutput": [
      "(Sub (Sum (Int 1) (Multi (Int 2) (Int 3))) (Rem (Div (Int 4) (Int 5)) (Int 2)))"
    ],
    "expectedErrorName": ""
  },
  {
    "name": "Grouped Expression",
    "input": "(1 + 2) * 3",
    "expectedOutput": [
      "(Multi (Sum (Int 1) (Int 2)) (Int 3))"
    ],
    "expectedErrorName": ""
  },
  {
    "name": "Unary Operators",
