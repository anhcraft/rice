# 37. Maximum Subarray
# Given an integer array nums, find the subarray with the largest sum and return its sum.
# Approach: Kadane's algorithm

const maxSubArray = func(nums) {
    var maxSum = nums[0];
    var currentSum = nums[0];

    for (var i = 1; i < len(nums); i++) {
        if currentSum + nums[i] > nums[i] {
            currentSum = currentSum + nums[i];
        } else {
            currentSum = nums[i];
        }
        if currentSum > maxSum {
            maxSum = currentSum;
        }
    }

    return maxSum;
};

# Test 1: Mixed positive and negative
assert(maxSubArray(list.of(-2, 1, -3, 4, -1, 2, 1, -5, 4)) == 6, "Maximum Subarray test 1 failed");

# Test 2: Single element
assert(maxSubArray(list.of(1)) == 1, "Maximum Subarray test 2 failed");

# Test 3: All positive
assert(maxSubArray(list.of(5, 4, -1, 7, 8)) == 23, "Maximum Subarray test 3 failed");

# Test 4: All negative
assert(maxSubArray(list.of(-1, -2, -3)) == -1, "Maximum Subarray test 4 failed");

# Test 5: Two elements
assert(maxSubArray(list.of(-1, 1)) == 1, "Maximum Subarray test 5 failed");

true
