# Math functions: sqrt, floor, ceil, pow, max, min, abs

# sqrt
const sqrt9 = math.sqrt(9);      # 3.0
const sqrt16 = math.sqrt(16.0);  # 4.0
const sqrt2 = math.sqrt(2);      # ~1.414...

# floor
const floor3_7 = math.floor(3.7);  # 3.0
const floor3 = math.floor(3);      # 3.0

# ceil
const ceil2_1 = math.ceil(2.1);    # 3.0
const ceil2 = math.ceil(2);        # 2.0

# pow
const pow2_3 = math.pow(2, 3);     # 8.0
const pow3_2 = math.pow(3, 2);     # 9.0
const pow2_0 = math.pow(2, 0);     # 1.0

# max
const maxA = math.max(1, 5, 3);    # 5
const maxB = math.max(-10, 0, 10); # 10
const maxC = math.max(42);         # 42 (single arg)

# min
const minA = math.min(1, 5, 3);    # 1
const minB = math.min(-10, 0, 10); # -10
const minC = math.min(42);         # 42 (single arg)

# abs
const absPos = math.abs(5);        # 5
const absNeg = math.abs(-5);       # 5
const absFloat = math.abs(-3.14);  # 3.14

sqrt9 == 3.0 && sqrt16 == 4.0 && sqrt2 > 1.4 && sqrt2 < 1.42 && floor3_7 == 3.0 && floor3 == 3.0 && ceil2_1 == 3.0 && ceil2 == 2.0 && pow2_3 == 8.0 && pow3_2 == 9.0 && pow2_0 == 1.0 && maxA == 5 && maxB == 10 && maxC == 42 && minA == 1 && minB == -10 && minC == 42 && absPos == 5 && absNeg == 5 && absFloat == 3.14
