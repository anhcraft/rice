# Assignment returns the new value (but cannot be chained)
var a = 5;

# Assignment in expression context
var b = a = 10;  # a becomes 10, assignment returns 10, b = 10

# Assignment as statement return (last statement in block)
{
    var x = 1;
    x = x + 2;  # block value should be 3
};

a == 10 && b == 10
