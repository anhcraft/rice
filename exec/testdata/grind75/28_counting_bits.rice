# 28. Counting Bits
# Given an integer n, return an array ans of length n + 1 such that for each i (0 <= i <= n),
# ans[i] is the number of 1's in the binary representation of i.
# Approach: DP - ans[i] = ans[i >> 1] + (i & 1)

const countBits = func(n) {
    const dp = list.new();
    dp.append(0); # dp[0] = 0

    for (var i = 1; i <= n; i++) {
        dp.append(dp[i / 2] + (i % 2));
    }

    return dp;
};

# Test 1: n = 2
const r1 = countBits(2);
assert(r1[0] == 0 && r1[1] == 1 && r1[2] == 1, "Counting Bits test 1 failed");

# Test 2: n = 5
const r2 = countBits(5);
assert(r2[0] == 0 && r2[1] == 1 && r2[2] == 1 && r2[3] == 2 && r2[4] == 1 && r2[5] == 2, "Counting Bits test 2 failed");

# Test 3: n = 0
const r3 = countBits(0);
assert(r3[0] == 0, "Counting Bits test 3 failed");

# Test 4: n = 7
const r4 = countBits(7);
assert(r4[7] == 3, "Counting Bits test 4 failed");

true
