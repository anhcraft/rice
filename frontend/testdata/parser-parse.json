    ],
    "expectedErrorName": ""
  },
  {
    "name": "Variadic Function Literal (Only variadic)",
    "input": "func(args...){ println(args) }",
    "expectedOutput": [
      "(Func (Id args)... (Block (Call (Id println) (Id args))))"
    ],
    "expectedErrorName": ""
  },
  {
    "name": "Variadic Function Literal (Mixed parameters)",
    "input": "func(format, args...){ printf(format, args); 1; }",
    "expectedOutput": [
