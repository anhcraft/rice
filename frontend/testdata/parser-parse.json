    ],
    "expectedErrorName": ""
  },
  {
    "name": "Standalone Increment/Decrement Statements",
    "input": "i++; --j;",
    "expectedOutput": [
      "(Post-incDec Inc (Id i))",
      "(Pre-incDec Dec (Id j))"
    ],
    "expectedErrorName": ""
  },
  {
    "name": "Illegal Increment/Decrement Statements",
    "input": "++1; --true;",
    "expectedOutput": [],
    "expectedErrorName": "expectReferenceErr"
  },
  {
    "name": "For Statement (C-style full)",
    "input": "for (var i = 0; i < 10; i++) { print(i) }",
    "expectedOutput": [
      "(For (Declare (Id i) (Int 0)) (Lt (Id i) (Int 10)) (Post-incDec Inc (Id i)) (Block (Call (Id print) (Id i))))"
    ],
    "expectedErrorName": ""
  },
  {
    "name": "For Statement (Condition-only)",
    "input": "for a < 5 { a = a + 1 }",
    "expectedOutput": [
      "(For () (Lt (Id a) (Int 5)) () (Block (Assign (Id a) (Sum (Id a) (Int 1)))))"
    ],
    "expectedErrorName": ""
  },
  {
    "name": "For-In Statement",
    "input": "for item in my_list { print(item) }",
    "expectedOutput": [
      "(ForIn (Id item) (Id my_list) (Block (Call (Id print) (Id item))))"
    ],
    "expectedErrorName": ""
  },
